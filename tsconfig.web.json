{
  "compilerOptions": {
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "target": "ES2022",
    "resolveJsonModule": true,
    "strict": true,
    "types": ["node", "vite/client"]
  },
  "include": ["web/**/*.ts", "shared/**/*.ts"]
}
